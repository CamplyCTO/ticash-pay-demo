{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@ticash/ui": [
        "../../packages/ui/src"
      ],
      "@ticash/i18n": [
        "../../packages/i18n/src"
      ],
      "@ticash/api-client": [
        "../../packages/api-client/src"
      ],
      "@ticash/core": [
        "../../packages/core/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
