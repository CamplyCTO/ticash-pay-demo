{
  "expo": {
    "name": "Ticash Agent",
    "slug": "ticash-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ticashagent",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#C9963C",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ticashpay.agent"
    },
    "android": {
      "package": "com.ticashpay.agent",
      "adaptiveIcon": {
        "backgroundColor": "#0B1F3A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1F3A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 96
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8211e42-3998-42ef-9c83-4753e7b84368"
      }
    },
    "owner": "camplyia"
  }
}
