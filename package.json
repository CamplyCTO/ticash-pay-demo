  "description": "Ticash Pay — Phase 1 financial core (auditable append-only double-entry ledger)",
  "license": "UNLICENSED",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
